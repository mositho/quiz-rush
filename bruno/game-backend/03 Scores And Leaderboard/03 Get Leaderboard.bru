meta {
  name: 03 Get Leaderboard
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/game/leaderboards?configurationKey={{configurationKey}}&limit=5
  body: none
  auth: none
}

tests {
  test("returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("returns leaderboard entries", function() {
    const body = res.getBody();
    expect(Array.isArray(body.entries)).to.equal(true);
    expect(body.entries.length).to.be.greaterThan(0);
  });
}
